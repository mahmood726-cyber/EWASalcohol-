# ==============================================================================

message("\n=== HETEROGENEITY TESTS ===")
heterogeneity <- mr_heterogeneity(harmonised_all)
print(heterogeneity %>% filter(method == "Inverse variance weighted"))

message("\n=== PLEIOTROPY TESTS (EGGER INTERCEPT) ===")
pleiotropy <- mr_pleiotropy_test(harmonised_all)
print(pleiotropy)

# ==============================================================================
# SECTION 7: INSTRUMENT STRENGTH ASSESSMENT
# ==============================================================================

message("\n=== CALCULATING F-STATISTICS ===")

f_stats <- exposure_dat %>%
  mutate(F_stat = (beta.exposure / se.exposure)^2)

mean_F <- mean(f_stats$F_stat)
min_F <- min(f_stats$F_stat)

message(paste("Mean F-statistic:", round(mean_F, 2)))
message(paste("Minimum F-statistic:", round(min_F, 2)))
message(paste("All F-statistics >10:", all(f_stats$F_stat > 10)))

# ==============================================================================
# SECTION 8: LEAVE-ONE-OUT ANALYSIS
# ==============================================================================

message("\n=== LEAVE-ONE-OUT ANALYSIS ===")

key_outcomes <- c("ebi-a-GCST005195", "ebi-a-GCST006907")
key_outcome_names <- c("CAD", "Large Artery Stroke")

loo_results <- list()
for (i in 1:length(key_outcomes)) {
  outcome_id <- key_outcomes[i]
  outcome_name <- key_outcome_names[i]
  
  dat_subset <- harmonised_all %>% filter(id.outcome == outcome_id)
  loo_result <- mr_leaveoneout(dat_subset)
  loo_results[[outcome_name]] <- loo_result
  
  # Identify influential SNPs
  loo_ivw <- loo_result %>% filter(SNP != "All")
  all_estimate <- loo_result %>% filter(SNP == "All") %>% pull(b)
  
  influential <- loo_ivw %>%
    mutate(change_percent = abs((b - all_estimate) / all_estimate) * 100) %>%
    filter(change_percent > 10)
  
  if (nrow(influential) > 0) {
    message(paste("\nInfluential SNPs for", outcome_name, ":"))
    print(influential %>% select(SNP, change_percent))
  }
}

# ==============================================================================
# SECTION 9: MULTIVARIABLE MR
# ==============================================================================

message("\n=== MULTIVARIABLE MR ANALYSIS ===")

# Function to perform MVMR
perform_mvmr <- function(outcome_id, outcome_name, outcome_data) {
  
  # Harmonize with alcohol exposure
  dat_harmonised <- harmonise_data(
    exposure_dat = exposure_dat,
    outcome_dat = outcome_data
  )
  
  # Get harmonized SNPs
  mvmr_snps <- dat_harmonised$SNP
  
  # Prepare MVMR input
  alcohol_data <- dat_harmonised %>%
    select(SNP, beta.exposure, se.exposure) %>%
    rename(beta.alcohol = beta.exposure, se.alcohol = se.exposure)
  
  smoking_data <- smoking_snps %>%
    filter(SNP %in% mvmr_snps) %>%
    select(SNP, beta.outcome, se.outcome) %>%
    rename(beta.smoking = beta.outcome, se.smoking = se.outcome)
  
  bmi_data <- bmi_snps %>%
    filter(SNP %in% mvmr_snps) %>%
    select(SNP, beta.outcome, se.outcome) %>%
    rename(beta.bmi = beta.outcome, se.bmi = se.outcome)
  
  mvmr_input <- dat_harmonised %>%
    select(SNP, beta.outcome, se.outcome) %>%
    left_join(alcohol_data, by = "SNP") %>%
    left_join(smoking_data, by = "SNP") %>%
    left_join(bmi_data, by = "SNP") %>%
    filter(!is.na(beta.alcohol) & !is.na(beta.smoking) & !is.na(beta.bmi))
  
  if (nrow(mvmr_input) < 3) {
    return(NULL)
  }
  
  # Weighted regression MVMR
  weights <- 1 / (mvmr_input$se.outcome^2)
  mvmr_model <- lm(beta.outcome ~ beta.alcohol + beta.smoking + beta.bmi - 1,
                   data = mvmr_input,
                   weights = weights)
  
  alcohol_coef <- summary(mvmr_model)$coefficients["beta.alcohol", ]
  
  return(data.frame(
    outcome = outcome_name,
    beta = alcohol_coef[1],
    se = alcohol_coef[2],
    pval = alcohol_coef[4],
    OR = exp(alcohol_coef[1]),
    OR_lci = exp(alcohol_coef[1] - 1.96 * alcohol_coef[2]),
    OR_uci = exp(alcohol_coef[1] + 1.96 * alcohol_coef[2]),
    n_snps = nrow(mvmr_input)
  ))
}

# Run MVMR for key outcomes
mvmr_results <- list()
for (outcome_name in c("CAD", "Stroke_LAS")) {
  outcome_data <- outcome_data_list[[outcome_name]]
  if (!is.null(outcome_data)) {
    mvmr_result <- perform_mvmr(outcome_ids[outcome_name], outcome_name, outcome_data)
    if (!is.null(mvmr_result)) {
      mvmr_results[[outcome_name]] <- mvmr_result
    }
  }
}

