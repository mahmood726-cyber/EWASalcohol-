# Function to safely extract data with rate limit handling
safe_extract <- function(extract_function, ..., wait_time = 30) {
  result <- tryCatch({
    extract_function(...)
  }, error = function(e) {
    if (grepl("429|Too many requests", e$message)) {
      message("Rate limit hit. Please wait and retry later.")
      return(NULL)
    } else {
      stop(e)
    }
  })
  
  if (!is.null(result) && wait_time > 0) {
    message(paste("Waiting", wait_time, "seconds to avoid rate limit..."))
    Sys.sleep(wait_time)
  }
  
  return(result)
}

