harmonised_all <- harmonise_data(
  exposure_dat = exposure_dat,
  outcome_dat = outcome_dat
)

message("\n=== RUNNING PRIMARY MR ANALYSIS ===")

# Run multiple MR methods
mr_results <- mr(harmonised_all, 
                 method_list = c("mr_ivw", 
                                "mr_egger_regression", 
                                "mr_weighted_median", 
                                "mr_weighted_mode"))

# Add outcome names
outcome_labels <- data.frame(
  id.outcome = outcome_ids,
  outcome_name = outcome_names
)

mr_results <- left_join(mr_results, outcome_labels, by = "id.outcome")

# Calculate odds ratios
mr_results <- mr_results %>%
  mutate(
    OR = exp(b),
    OR_lci = exp(b - 1.96 * se),
    OR_uci = exp(b + 1.96 * se)
  )

# Display main results
ivw_results <- mr_results %>%
  filter(method == "Inverse variance weighted") %>%
  select(outcome_name, nsnp, OR, OR_lci, OR_uci, pval)

message("\n=== UNIVARIATE RESULTS (IVW) ===")
print(ivw_results)

