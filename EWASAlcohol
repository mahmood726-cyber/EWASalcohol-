# Function to perform MVMR for each outcome
perform_mvmr <- function(outcome_id, outcome_name) {
  message(paste("\nMVMR for", outcome_name))
  
  # Get outcome data for alcohol SNPs
  outcome_data <- outcome_data_list[[outcome_name]]
  
  if (is.null(outcome_data)) {
    message("No outcome data available")
    return(NULL)
  }
  
  # Harmonize with alcohol exposure
  dat_harmonised <- harmonise_data(exposure_dat = exposure_dat,
                                   outcome_dat = outcome_data)
  
  # Get harmonized SNPs
  mvmr_snps <- dat_harmonised$SNP
  
  # Prepare MVMR input data
  alcohol_data <- dat_harmonised %>%
    select(SNP, beta.exposure, se.exposure) %>%
    rename(beta.alcohol = beta.exposure, se.alcohol = se.exposure)
  
  smoking_data <- smoking_snps %>%
    filter(SNP %in% mvmr_snps) %>%
    select(SNP, beta.outcome, se.outcome) %>%
    rename(beta.smoking = beta.outcome, se.smoking = se.outcome)
  
  bmi_data <- bmi_snps %>%
    filter(SNP %in% mvmr_snps) %>%
    select(SNP, beta.outcome, se.outcome) %>%
    rename(beta.bmi = beta.outcome, se.bmi = se.outcome)
  
  mvmr_input <- dat_harmonised %>%
    select(SNP, beta.outcome, se.outcome) %>%
    left_join(alcohol_data, by = "SNP") %>%
    left_join(smoking_data, by = "SNP") %>%
    left_join(bmi_data, by = "SNP") %>%
    filter(!is.na(beta.alcohol) & !is.na(beta.smoking) & !is.na(beta.bmi))
  
  if (nrow(mvmr_input) < 3) {
    message("Insufficient SNPs for MVMR")
    return(NULL)
  }
  
  # Weighted regression MVMR
  weights <- 1 / (mvmr_input$se.outcome^2)
  mvmr_model <- lm(beta.outcome ~ beta.alcohol + beta.smoking + beta.bmi - 1,
                   data = mvmr_input,
                   weights = weights)
  
  alcohol_coef <- summary(mvmr_model)$coefficients["beta.alcohol", ]
  
  return(data.frame(
    outcome = outcome_name,
    beta = alcohol_coef[1],
    se = alcohol_coef[2],
    pval = alcohol_coef[4],
    OR = exp(alcohol_coef[1]),
    OR_lci = exp(alcohol_coef[1] - 1.96 * alcohol_coef[2]),
    OR_uci = exp(alcohol_coef[1] + 1.96 * alcohol_coef[2]),
    n_snps = nrow(mvmr_input)
  ))
}

# Run MVMR for key outcomes
