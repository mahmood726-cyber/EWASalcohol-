  dat_subset <- harmonised_dat %>% filter(id.outcome == outcome_id)
  
  if (nrow(dat_subset) >= 3) {
    tryCatch({
      presso_result <- mr_presso(
        BetaOutcome = "beta.outcome",
        BetaExposure = "beta.exposure",
        SdOutcome = "se.outcome",
        SdExposure = "se.exposure",
        OUTLIERtest = TRUE,
        DISTORTIONtest = TRUE,
        data = dat_subset,
        NbDistribution = 1000,
        SignifThreshold = 0.05
      )
      presso_results[[outcome_id]] <- presso_result
      
      main_result <- presso_result$`Main MR results`
      raw <- main_result[1, ]
      message(paste(outcome_id, "- Raw OR:", 
                   round(exp(raw$`Causal Estimate`), 3),
                   "p =", round(raw$`P-value`, 4)))
      
    }, error = function(e) {
      message(paste(outcome_id, "- MR-PRESSO failed"))
    })
  }
}

