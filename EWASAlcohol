# SECTION 4: EXTRACT OUTCOME DATA
# ==============================================================================

message("\n=== EXTRACTING OUTCOME DATA ===")

outcome_data_list <- list()

for (i in seq_along(outcome_ids)) {
  outcome_id <- outcome_ids[i]
  outcome_name <- names(outcome_ids)[i]
  
  message(paste0("\nProcessing ", outcome_name, " (", i, "/", length(outcome_ids), ")"))
  
  outcome_data <- extract_outcome_data(
    snps = exposure_dat$SNP,
    outcomes = outcome_id,
    proxies = FALSE
  )
  
  if (!is.null(outcome_data)) {
    outcome_data_list[[outcome_name]] <- outcome_data
    message(paste("✓ Successfully extracted", outcome_name))
  }
  
  if (i < length(outcome_ids)) {
    Sys.sleep(30)  # Pause between requests
  }
}

# Combine all outcome data
outcome_dat <- bind_rows(outcome_data_list)

